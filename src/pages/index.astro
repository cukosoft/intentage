---
const acceptLang = Astro.request.headers.get('accept-language') || '';
const supported = ['tr','en','ar','de','fr','es','it','pt','ru','ja','ko','zh','nl'];

function detectLocale(header: string): string {
  const langs = header.split(',').map(part => {
    const [lang, q] = part.trim().split(';q=');
    return { lang: lang.split('-')[0].toLowerCase(), q: q ? parseFloat(q) : 1 };
  }).sort((a, b) => b.q - a.q);

  for (const { lang } of langs) {
    if (supported.includes(lang)) return lang;
  }
  return 'en';
}

const locale = detectLocale(acceptLang);
return Astro.redirect(`/${locale}/`);
