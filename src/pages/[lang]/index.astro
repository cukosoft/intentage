---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';

export const prerender = true;

export function getStaticPaths() {
  const locales = ['tr','en','ar','de','fr','es','it','pt','ru','ja','ko','zh','nl'];
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const allPosts = await getCollection('posts');
const pinnedSlugs = new Set(['niyet-kaybinin-olumu', 'death-of-intent-loss']);

function getPreviewParagraphs(body: string, fallback: string) {
  const paragraphs = body
    .split(/\r?\n\r?\n/)
    .map((part) => part.replace(/\*\*/g, '').replace(/\r?\n/g, ' ').trim())
    .filter((part) => part.length > 0)
    .slice(0, 3);

  return paragraphs.length > 0 ? paragraphs : [fallback];
}

const posts = allPosts
  .filter(post => post.id.startsWith(`${lang}/`))
  .sort((a, b) => {
    const aPinned = pinnedSlugs.has(a.data.slug);
    const bPinned = pinnedSlugs.has(b.data.slug);

    if (aPinned && !bPinned) return -1;
    if (!aPinned && bPinned) return 1;

    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
  })
  .map((post) => ({
    ...post,
    previewParagraphs: getPreviewParagraphs(post.body, post.data.excerpt),
  }));

