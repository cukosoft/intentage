---
interface Props {
  title: string;
  description?: string;
  locale: string;
  slug?: string;
}

const { title, description = 'Intent Age вҖ” Where intent becomes interface.', locale, slug } = Astro.props;

const locales = ['tr','en','ar','de','fr','es','it','pt','ru','ja','ko','zh','nl'];
const localeNames: Record<string, string> = {
  tr: 'TГјrkГ§e',
  en: 'English',
  ar: 'Ш§Щ„Ш№ШұШЁЩҠШ©',
  de: 'Deutsch',
  fr: 'FranГ§ais',
  es: 'EspaГұol',
  it: 'Italiano',
  pt: 'PortuguГӘs',
  ru: 'Р СғСҒСҒРәРёР№',
  ja: 'ж—Ҙжң¬иӘһ',
  ko: 'н•ңкөӯм–ҙ',
  zh: 'дёӯж–Ү',
  nl: 'Nederlands',
};

const localeFlags: Record<string, string> = {
  tr: 'рҹҮ№рҹҮ·', en: 'рҹҮ¬рҹҮ§', ar: 'рҹҮёрҹҮҰ', de: 'рҹҮ©рҹҮӘ', fr: 'рҹҮ«рҹҮ·',
  es: 'рҹҮӘрҹҮё', it: 'рҹҮ®рҹҮ№', pt: 'рҹҮ§рҹҮ·', ru: 'рҹҮ·рҹҮә', ja: 'рҹҮҜрҹҮө',
  ko: 'рҹҮ°рҹҮ·', zh: 'рҹҮЁрҹҮі', nl: 'рҹҮірҹҮұ',
};

const dir = locale === 'ar' ? 'rtl' : 'ltr';
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang={locale} dir={dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={new URL(currentPath, Astro.site).href} />
  {locales.map(l => {
    const altPath = currentPath.replace(`/${locale}/`, `/${l}/`);
    return <link rel="alternate" hreflang={l} href={new URL(altPath, Astro.site).href} />;
  })}
  <link rel="alternate" hreflang="x-default" href={new URL(currentPath.replace(`/${locale}/`, '/en/'), Astro.site).href} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;1,8..60,300;1,8..60,400&display=swap');
  </style>
</head>
<body>
  <header class="site-header">
    <a href={`/${locale}/`} class="site-logo"><span class="logo-age">AGE</span> <span class="logo-of">OF</span> <span class="logo-intent">INTENT</span></a>
    <div class="lang-switcher">
      <button class="lang-switcher-btn" id="langBtn">
        {localeFlags[locale]}
      </button>
      <div class="lang-dropdown" id="langDropdown">
        {locales.map(l => {
          const targetPath = currentPath.replace(`/${locale}/`, `/${l}/`);
          return (
            <a href={targetPath} class={l === locale ? 'active' : ''}>
              <span class="flag">{localeFlags[l]}</span> {localeNames[l]}
            </a>
          );
        })}
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    Intent Age &copy; {new Date().getFullYear()}
  </footer>

  <script>
    import { inject } from '@vercel/analytics';
    inject();
  </script>

  <script>
    const btn = document.getElementById('langBtn');
    const dropdown = document.getElementById('langDropdown');
    btn?.addEventListener('click', () => dropdown?.classList.toggle('open'));
    document.addEventListener('click', (e) => {
      if (!btn?.contains(e.target as Node) && !dropdown?.contains(e.target as Node)) {
        dropdown?.classList.remove('open');
      }
    });
  </script>
</body>
</html>
